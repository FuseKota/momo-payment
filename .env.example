# ===================
# Supabase
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# Stripe
# ===================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===================
# Email (Resend)
# ===================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com

# ===================
# Google Calendar（飯舘村台湾夜市カレンダーの読み取り元）
# ===================
# GCP のサービスアカウントを作成し、対象の Google カレンダーを
# このメールアドレスに「予定の表示（全詳細）」権限で共有すること
GOOGLE_CALENDAR_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# サービスアカウント JSON の private_key。改行は \n エスケープで 1 行記述する
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
# 対象カレンダー ID（Google カレンダー設定 > カレンダーの統合 > カレンダー ID）
GOOGLE_CALENDAR_ID=xxxxxxxx@group.calendar.google.com
# タイムゾーン（既定: Asia/Tokyo）
GOOGLE_CALENDAR_TIMEZONE=Asia/Tokyo

# ===================
# App
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 送料（円）
SHIPPING_FEE_YEN=1200
